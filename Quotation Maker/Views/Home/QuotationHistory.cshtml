                            </div>

                            <div class="input-group mb-2">
                                <span class="input-group-text" id="inputGroup-sizing-default">Rate:</span>
                                <input type="text" class="form-control" id="laborrate" aria-label="Sizing example input" aria-describedby="inputGroup-sizing-default" placeholder="N/A" readonly>
                            </div>

                            <div class="input-group mb-2">
                                <span class="input-group-text" id="inputGroup-sizing-default">Total Amount:</span>
                                <input type="text" class="form-control" id="totallabor" aria-label="Sizing example input" aria-describedby="inputGroup-sizing-default" placeholder="N/A" readonly>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer d-flex justify-content-center">
                        <button type="button" class="btn btn-success" id="addLaborModal">Add</button>
                        <button type="button" class="btn btn-danger" id="laborclose" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="loader" tabindex="-1" aria-hidden="true" data-backdrop="static" data-keyboard="false">
            <div class="modal-dialog modal-dialog-centered modal-xs d-flex justify-content-center">
                <div class="modal-content" style="width:auto;">
                    <div class="modal-body">
                        @Html.Partial("Loader")
                    </div>
                </div>
            </div>
        </div>

    </div>
</body>
</html>
